---
export interface Props {
  skills: string[];
}

const { skills } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {skills.map(skill => (
    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-accent-light text-accent-dark border border-accent/20">
      {skill}
    </span>
  ))}
</div>
