---
const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Career', href: '#career' },
  { label: 'Playground', href: '#playground' },
];
---

<nav class="fixed top-0 w-full bg-white/70 backdrop-blur-md z-50 border-b border-slate-200/60">
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="#" class="text-lg font-semibold text-text-primary tracking-tight">Yuto Suzuki</a>
    <ul class="flex gap-6">
      {navItems.map(item => (
        <li>
          <a href={item.href} class="text-sm font-medium text-text-secondary hover:text-accent transition-colors nav-link">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
