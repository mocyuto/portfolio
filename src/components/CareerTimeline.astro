---
interface CareerItem {
  period: string;
  company: string;
  role: string;
  description?: string;
}

const careers: CareerItem[] = [
  {
    period: '2023 - Present',
    company: 'Gunosy inc.',
    role: 'Engineering Manager',
    description: '新規事業開発室 / 組織マネジメントと技術戦略の策定',
  },
  {
    period: '2018 - 2023',
    company: 'Gunosy inc.',
    role: 'Lead Software Engineer',
    description: '高トラフィックモバイル計測・広告配信システムのアーキテクチャ設計',
  },
  {
    period: '2013 - 2018',
    company: 'CyberZ inc. / CyberAgent inc.',
    role: 'Software Engineer',
    description: '広告配信システムの開発',
  },
];

const education = [
  { period: '2011 - 2013', school: 'Tokyo Institute of Technology', degree: 'M.S. NLP' },
  { period: '2007 - 2011', school: 'Tokyo Institute of Technology', degree: 'B.S. Computer Science' },
];
---

<section id="career" class="py-20 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-text-primary mb-12">Career</h2>

    <div class="relative border-l-2 border-slate-200 ml-3">
      {careers.map(item => (
        <div class="relative pl-8 pb-10 scroll-reveal">
          <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-accent border-4 border-white shadow"></div>
          <div class="text-sm font-medium text-accent mb-1">{item.period}</div>
          <h3 class="text-lg font-semibold text-text-primary">{item.company}</h3>
          <p class="text-text-secondary font-medium">{item.role}</p>
          {item.description && <p class="text-text-muted text-sm mt-1">{item.description}</p>}
        </div>
      ))}
    </div>

    <h3 class="text-xl font-bold text-text-primary mt-8 mb-6">Education</h3>
    <div class="relative border-l-2 border-slate-200 ml-3">
      {education.map(item => (
        <div class="relative pl-8 pb-8 scroll-reveal">
          <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-text-muted border-4 border-white shadow"></div>
          <div class="text-sm font-medium text-text-muted mb-1">{item.period}</div>
          <h4 class="text-base font-semibold text-text-primary">{item.school}</h4>
          <p class="text-text-secondary text-sm">{item.degree}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('opacity-100', 'translate-y-0');
        entry.target.classList.remove('opacity-0', 'translate-y-4');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.scroll-reveal').forEach(el => {
    el.classList.add('opacity-0', 'translate-y-4', 'transition-all', 'duration-500');
    observer.observe(el);
  });
</script>
